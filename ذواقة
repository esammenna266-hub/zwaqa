                        <span class="food-rating">⭐ 4.8 (120)</span>
                    </div>
                    <button class="add-to-cart" onclick="addToCart(event, 1)">+ إضافة إلى السلة</button>
                </div>
            </div>
            
            <div class="food-card" onclick="showFoodDetails(2)">
                <img src="https://images.unsplash.com/photo-1574071318508-1cdbab80d002?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60" 
                     alt="بيتزا مارغريتا" class="food-image">
                <div class="food-info">
                    <h3 class="food-title">بيتزا مارغريتا</h3>
                    <p class="food-description">جبنة موزاريلا وطماطم طازجة وأوريجانو</p>
                    <div class="food-meta">
                        <span class="food-price">35.00 ج</span>
                        <span class="food-rating">⭐ 4.9 (95)</span>
                    </div>
                    <button class="add-to-cart" onclick="addToCart(event, 2)">+ إضافة إلى السلة</button>
                </div>
            </div>
        </div>
        
        <nav class="bottom-nav">
            <a href="#" class="nav-item active" onclick="showPage('homePage')">
                <div class="nav-icon">🏠</div>
                <div class="nav-text">الرئيسية</div>
            </a>
            <a href="#" class="nav-item" onclick="showPage('ordersPage')">
                <div class="nav-icon">📋</div>
                <div class="nav-text">طلباتي</div>
            </a>
            <a href="#" class="nav-item" onclick="showPage('trackingPage')">
                <div class="nav-icon">📍</div>
                <div class="nav-text">تتبع</div>
            </a>
            <a href="#" class="nav-item" onclick="showPage('profilePage')">
                <div class="nav-icon">👤</div>
                <div class="nav-text">حسابي</div>
            </a>
        </nav>
    </div>
    
    <!-- صفحة تتبع الطلب -->
    <div id="trackingPage" class="page">
        <div class="tracking-container">
            <button class="back-button" onclick="showPage('homePage')">
                <i class="fas fa-arrow-right"></i>
            </button>
            
            <div class="order-header">
                <div class="order-number">الطلب #FD-2024-1254</div>
                <h2>تتبع طلبك</h2>
                <p>برجر كلاسيك ×2 • بيتزا مارغريتا ×1</p>
            </div>
            
            <div class="timeline">
                <div class="timeline-step completed">
                    <div class="step-marker">
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="step-content">
                        <div class="step-title">تم تأكيد الطلب</div>
                        <div class="step-time">10:30 صباحاً</div>
                    </div>
                </div>
                
                <div class="timeline-step completed">
                    <div class="step-marker">
                        <i class="fas fa-utensils"></i>
                    </div>
                    <div class="step-content">
                        <div class="step-title">قيد التحضير</div>
                        <div class="step-time">10:35 صباحاً</div>
                    </div>
                </div>
                
                <div class="timeline-step active">
                    <div class="step-marker">
                        <i class="fas fa-motorcycle"></i>
                    </div>
                    <div class="step-content">
                        <div class="step-title">في الطريق إليك</div>
                        <div class="step-time">10:50 صباحاً</div>
                    </div>
                </div>
                
                <div class="timeline-step">
                    <div class="step-marker">
                        <i class="fas fa-home"></i>
                    </div>
                    <div class="step-content">
                        <div class="step-title">تم التسليم</div>
                        <div class="step-time">--:--</div>
                    </div>
                </div>
            </div>
            
            <div class="eta-card">
                <div>الوقت المتوقع للتسليم</div>
                <div class="countdown" id="countdownTimer">15:24</div>
                <div>متبقي على وصول طلبك</div>
            </div>
            
            <div class="driver-card">
                <div class="driver-info">
                    <div class="driver-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <div>
                        <h3>أحمد محمد</h3>
                        <p>⭐ 4.7 (124 تقييم)</p>
                    </div>
                </div>
                
                <div class="contact-buttons">
                    <button class="contact-btn call-btn" onclick="callDriver()">
                        <i class="fas fa-phone"></i> اتصل
                    </button>
                    <button class="contact-btn message-btn" onclick="messageDriver()">
                        <i class="fas fa-comment"></i> رسالة
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- صفحة الطلبات -->
    <div id="ordersPage" class="page">
        <nav class="navbar">
            <button class="back-button" onclick="showPage('homePage')">
                <i class="fas fa-arrow-right"></i>
            </button>
            <h3>طلباتي</h3>
            <div></div>
        </nav>
        
        <div style="padding: 20px;">
            <div class="food-card">
                <div class="food-info">
                    <h3>الطلب #1254</h3>
                    <p>برجر كلاسيك ×2 • بيتزا مارغريتا ×1</p>
                    <div class="food-meta">
                        <span class="food-price">85.50 ج</span>
                        <span style="color: var(--success);">✅ منجز</span>
                    </div>
                    <button class="add-to-cart" onclick="showPage('trackingPage')">تتبع الطلب</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- صفحة الملف الشخصي -->
    <div id="profilePage" class="page">
        <nav class="navbar">
            <button class="back-button" onclick="showPage('homePage')">
                <i class="fas fa-arrow-right"></i>
            </button>
            <h3>حسابي</h3>
            <div></div>
        </nav>
        
        <div style="padding: 20px; text-align: center;">
            <div style="width: 100px; height: 100px; background: #ddd; border-radius: 50%; margin: 20px auto; display: flex; align-items: center; justify-content: center; font-size: 40px;">
                👤
            </div>
            <h3>محمد أحمد</h3>
            <p>mohamed@example.com</p>
            
            <div style="margin-top: 30px;">
                <button class="add-to-cart" style="margin-bottom: 10px;">📋 طلباتي</button>
                <button class="add-to-cart" style="margin-bottom: 10px; background: #6C757D;">⚙️ الإعدادات</button>
                <button class="add-to-cart" style="background: var(--danger);">🚪 تسجيل خروج</button>
            </div>
        </div>
    </div>
    
    <!-- صفحة السلة -->
    <div id="cartPage" class="page">
        <nav class="navbar">
            <button class="back-button" onclick="showPage('homePage')">
                <i class="fas fa-arrow-right"></i>
            </button>
            <h3>سلة المشتريات</h3>
            <div></div>
        </nav>
        
        <div style="padding: 20px;">
            <div class="food-card">
                <div class="food-info">
                    <h3>برجر كلاسيك ×2</h3>
                    <div class="food-meta">
                        <span class="food-price">51.98 ج</span>
                        <button onclick="removeFromCart(1)" style="background: var(--danger); color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer;">حذف</button>
                    </div>
                </div>
            </div>
            
            <div style="background: white; padding: 20px; border-radius: 15px; margin-top: 20px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span>المجموع الفرعي</span>
                    <span>51.98 ر.س</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
                    <span>رسوم التوصيل</span>
                    <span>10.00 ج</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 18px; border-top: 1px solid #eee; padding-top: 10px;">
                    <span>الإجمالي</span>
                    <span style="color: var(--primary);">61.98 ج</span>
                </div>
                
                <button class="add-to-cart" style="margin-top: 20px;" onclick="checkout()">
                    <i class="fas fa-shopping-bag"></i> اتمام الشراء
                </button>
            </div>
        </div>
    </div>

    <script>
        // دالة تبديل الصفحات
        function showPage(pageId) {
            // إخفاء كل الصفحات
            document.querySelectorAll('.page').forEach(page => {
                page.classList.remove('active');
            });
            
            // إزالة النشاط من عناصر التنقل
            document.querySelectorAll('.nav-item').forEach(item => {
                item.classList.remove('active');
            });
            
            // إظهار الصفحة المطلوبة
            document.getElementById(pageId).classList.add('active');
            
            // تحديث العنصر النشط في التنقل السفلي
            if (pageId === 'homePage') {
                document.querySelector('.nav-item').classList.add('active');
            }
        }
        
        // دالة إضافة إلى السلة
        function addToCart(event, itemId) {
            event.stopPropagation();
            alert("تم إضافة المنتج إلى السلة!");
            
            // تحديث عداد السلة
            const cartCount = document.querySelector('.cart-count');
            let count = parseInt(cartCount.textContent);
            cartCount.textContent = count + 1;
        }
        
        // دالة إزالة من السلة
        function removeFromCart(itemId) {
            const cartCount = document.querySelector('.cart-count');
            let count = parseInt(cartCount.textContent);
            cartCount.textContent = Math.max(0, count - 1);
            showPage('homePage');
        }
        
        // دالة الاتصال بالسائق
        function callDriver() {
            alert("📞 جاري الاتصال بالسائق أحمد...");
        }
        
        // دالة المراسلة
        function messageDriver() {
            alert("📱 يمكنك مراسلة السائق عبر التطبيق");
        }
        
        // دالة الدفع
        function checkout() {
            alert("🚀 جاري تحويلك إلى صفحة الدفع...");
        }
        
        // فلترة الفئات
        function filterCategory(category) {
            document.querySelectorAll('.category-item').forEach(item => {
                item.classList.remove('active');
            });
            event.target.closest('.category-item').classList.add('active');
            alert(`عرض منتجات: ${category}`);
        }
        
        // عرض تفاصيل الطعام
        function showFoodDetails(foodId) {
            alert(`تفاصيل المنتج #${foodId}\n\nستفتح صفحة التفاصيل هنا`);
        }
        
        // مؤقت العد التنازلي
        function startCountdown() {
            let minutes = 15;
            let seconds = 24;
            const timerElement = document.getElementById('countdownTimer');
            
            setInterval(() => {
                if (seconds === 0) {
                    if (minutes === 0) {
                        timerElement.textContent = "00:00";
                        return;
                    }
                    minutes--;
                    seconds = 59;
                } else {
                    seconds--;
                }
                
                timerElement.textContent = 
                    `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }, 1000);
        }
        
        // تشغيل المؤقت عند تحميل الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            startCountdown();
        });
    </script>
</body>
</html>